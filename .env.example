# Production (Vercel + recommended default)
NEXT_PUBLIC_CONVEX_URL=https://savory-hippopotamus-103.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://savory-hippopotamus-103.convex.site
CONVEX_DEPLOYMENT=prod:savory-hippopotamus-103

# Vercel: set NEXT_PUBLIC_CONVEX_URL and NEXT_PUBLIC_CONVEX_SITE_URL in Project → Settings → Environment Variables.
# Default `npm run build` is `next build` only (committed convex/_generated). Deploy Convex separately: npm run convex:deploy:prod
# Optional — auto-deploy Convex on each Vercel build: override Build Command to:
#   npx convex deploy --cmd-url-env-var-name NEXT_PUBLIC_CONVEX_URL --cmd 'npm run build'
# and add CONVEX_DEPLOY_KEY (Production deploy key from Convex Dashboard → Deployment Settings → General).

# Dev only (optional local sandbox)
# NEXT_PUBLIC_CONVEX_URL=https://accomplished-dragon-257.convex.cloud
# NEXT_PUBLIC_CONVEX_SITE_URL=https://accomplished-dragon-257.convex.site
# CONVEX_DEPLOYMENT=dev:accomplished-dragon-257
